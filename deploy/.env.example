# Fluent Stack — Environment Variables
# Copy this file to .env and fill in the required values.

# ── L1 Configuration (REQUIRED) ──────────────────────────────────────
L1_RPC_URL=
L1_CONTRACT_ADDR=
L1_SUBMITTER_KEY=
NITRO_VERIFIER_ADDR=

# ── L1 Optional ──────────────────────────────────────────────────────
L1_START_BLOCK=0
FLUENT_START_BATCH_ID=
FLUENT_L1_DEPLOY_BLOCK=0
L1_BEACON_URL=
BEACON_GENESIS_TIMESTAMP=1606824023

# ── Proxy (REQUIRED) ─────────────────────────────────────────────────
API_KEY=
EIF_PATH=/enclave.eif
SP1_ELF_PATH=/app/bin/sp1.elf
SP1_PRIVATE_KEY=
RPC_URL=http://127.0.0.1:8545

# ── AWS (for Nitro enclave) ──────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# ── Courier ──────────────────────────────────────────────────────────
FLUENT_API_KEY=
FLUENT_HTTP_TIMEOUT_SECS=120
FLUENT_FALLBACK_LOCAL_RPC=
FLUENT_FALLBACK_REMOTE_RPC=
FLUENT_MAX_CONCURRENT_FALLBACKS=4

# ── Node ─────────────────────────────────────────────────────────────
FLUENT_WITNESS_COLD_MAX_BYTES=10737418240

# ── Logging ──────────────────────────────────────────────────────────
RUST_LOG=info
